# Specter-DIY local development environment
# Usage: source .env

# Workaround for NVIDIA + SDL2 segfault in simulator
# Remove or change to "gl" if your GPU driver works fine
export SDL_VIDEODRIVER=software

# Bitcoin Core RPC is auto-started by the test runners (run_tests.py,
# run_integration.py) if `bitcoind` is found in PATH. No manual setup needed.
# To skip RPC tests, uninstall bitcoind or set BTC_SKIP_RPC=1.
# export BTC_SKIP_RPC=1
